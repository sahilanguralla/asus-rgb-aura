Build-Depends: debhelper (>= 10)
Standards-Version: 4.1.3

Package: asus-rgb-control
Architecture: all
Depends: ${misc:Depends}, whiptail, git, make, gcc, autoconf, libusb-1.0-0-dev, python3-gi, gir1.2-gtk-3.0
Description: ASUS ROG Keyboard RGB Control Scripts
 A user-friendly interactive menu and cycle script to manage ASUS ROG keyboard
 RGB lighting using rogauracore. This package automatically sets up the required
 udev rules and attempts to install rogauracore from source if it is not already
 present on the system.
