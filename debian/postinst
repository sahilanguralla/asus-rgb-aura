#!/bin/bash
set -e

# Reload udev rules to apply the new 99-rogauracore.rules
echo "Reloading udev rules..."
udevadm control --reload-rules || true
udevadm trigger || true

# Check if rogauracore is installed
if ! command -v rogauracore &> /dev/null; then
    echo "rogauracore not found. Downloading and compiling..."
    
    BUILD_DIR="/tmp/rogauracore_build_$$"
    mkdir -p "$BUILD_DIR"
    
    git clone --depth 1 https://github.com/wroberts/rogauracore.git "$BUILD_DIR"
    cd "$BUILD_DIR"
    
    echo "Configuring rogauracore..."
    autoreconf -i
    ./configure
    
    echo "Compiling rogauracore..."
    make
    
    echo "Installing rogauracore..."
    make install
    
    cd /
    rm -rf "$BUILD_DIR"
    
    echo "rogauracore installed successfully!"
else
    echo "rogauracore is already installed."
fi

exit 0
