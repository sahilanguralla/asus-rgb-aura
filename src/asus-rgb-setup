#!/usr/bin/env python3
import gi
import subprocess
import ast

gi.require_version('Gtk', '3.0')
from gi.repository import Gtk, Gdk

def add_custom_shortcut(shortcut_id, name, command, binding):
    schema = 'org.gnome.settings-daemon.plugins.media-keys'
    key = 'custom-keybindings'
    
    try:
        output = subprocess.check_output(['gsettings', 'get', schema, key], text=True).strip()
    except Exception as e:
        print("Error getting gsettings:", e)
        return False
        
    if output == '@as []':
        bindings = []
    else:
        try:
            bindings = ast.literal_eval(output)
        except Exception:
            bindings = []
            
    new_path = f"/org/gnome/settings-daemon/plugins/media-keys/custom-keybindings/{shortcut_id}/"
    if new_path not in bindings:
        bindings.append(new_path)
        
    bindings_str = str(bindings).replace("'", '"')
    
    try:
        subprocess.run(['gsettings', 'set', schema, key, bindings_str], check=True)
        schema_custom = 'org.gnome.settings-daemon.plugins.media-keys.custom-keybinding'
        path_arg = schema_custom + ':' + new_path
        subprocess.run(['gsettings', 'set', path_arg, 'name', name], check=True)
        subprocess.run(['gsettings', 'set', path_arg, 'command', command], check=True)
        subprocess.run(['gsettings', 'set', path_arg, 'binding', binding], check=True)
        return True
    except Exception as e:
        print("Error setting custom keybinding:", e)
        return False

def build_binding_string(event):
    keyname = Gdk.keyval_name(event.keyval)
    if not keyname:
        return None
    # Ignore lone modifier keys
    if keyname in ['Control_L', 'Control_R', 'Shift_L', 'Shift_R',
                   'Alt_L', 'Alt_R', 'Super_L', 'Super_R']:
        return None
    mods = ""
    if event.state & Gdk.ModifierType.CONTROL_MASK:
        mods += "<Primary>"
    if event.state & Gdk.ModifierType.MOD1_MASK:
        mods += "<Alt>"
    if event.state & Gdk.ModifierType.SHIFT_MASK:
        mods += "<Shift>"
    if event.state & Gdk.ModifierType.SUPER_MASK:
        mods += "<Super>"
    return mods + keyname

class SetupWindow(Gtk.Window):
    def __init__(self):
        super().__init__(title="ASUS RGB Setup")
        self.set_border_width(20)
        self.set_default_size(450, 300)

        vbox = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=15)
        self.add(vbox)

        try:
            with open("/sys/class/dmi/id/product_name", "r") as f:
                model = f.read().strip()
        except Exception:
            model = "Unknown"

        if "G531" in model or "Scar" in model or "ROG" in model:
            lbl = Gtk.Label(label=f"Detected ASUS ROG ({model})!\n\nBind your Aura keys below.")
        else:
            lbl = Gtk.Label(label=f"Detected Model: {model}\n\nBind your RGB control keys below.")
        
        lbl.set_justify(Gtk.Justification.CENTER)
        vbox.pack_start(lbl, False, False, 0)

        # Separator
        vbox.pack_start(Gtk.Separator(), False, False, 5)

        # Next Effect button
        next_label = Gtk.Label(label="Next Effect (e.g., Fn+Right)")
        next_label.set_halign(Gtk.Align.START)
        vbox.pack_start(next_label, False, False, 0)

        self.btn_next = Gtk.Button(label="Click to Bind Key")
        self.btn_next.connect("clicked", self.on_btn_next_clicked)
        self.btn_next.set_size_request(200, 45)
        vbox.pack_start(self.btn_next, False, False, 0)

        # Separator
        vbox.pack_start(Gtk.Separator(), False, False, 5)

        # Previous Effect button
        prev_label = Gtk.Label(label="Previous Effect (e.g., Fn+Left)")
        prev_label.set_halign(Gtk.Align.START)
        vbox.pack_start(prev_label, False, False, 0)

        self.btn_prev = Gtk.Button(label="Click to Bind Key")
        self.btn_prev.connect("clicked", self.on_btn_prev_clicked)
        self.btn_prev.set_size_request(200, 45)
        vbox.pack_start(self.btn_prev, False, False, 0)

        # State tracking
        self.listening_for = None  # "next" or "prev"
        self.connect("key-press-event", self.on_key_press)

    def on_btn_next_clicked(self, widget):
        self.btn_next.set_label("Listening... Press a key!")
        self.btn_prev.set_sensitive(False)
        self.listening_for = "next"

    def on_btn_prev_clicked(self, widget):
        self.btn_prev.set_label("Listening... Press a key!")
        self.btn_next.set_sensitive(False)
        self.listening_for = "prev"

    def on_key_press(self, widget, event):
        if not self.listening_for:
            return False

        binding = build_binding_string(event)
        if not binding:
            return False

        if self.listening_for == "next":
            success = add_custom_shortcut(
                "asus-rgb-next",
                "ASUS RGB Next Effect",
                "/usr/bin/asus-rgb-cycle next",
                binding
            )
            btn = self.btn_next
        else:
            success = add_custom_shortcut(
                "asus-rgb-prev",
                "ASUS RGB Previous Effect",
                "/usr/bin/asus-rgb-cycle prev",
                binding
            )
            btn = self.btn_prev

        if success:
            direction = "Next" if self.listening_for == "next" else "Previous"
            dialog = Gtk.MessageDialog(
                transient_for=self,
                flags=0,
                message_type=Gtk.MessageType.INFO,
                buttons=Gtk.ButtonsType.OK,
                text="Success!"
            )
            dialog.format_secondary_text(
                f"Bound '{binding}' to {direction} Effect."
            )
            dialog.run()
            dialog.destroy()
            btn.set_label(f"Bound: {binding}  (Click to re-bind)")
        else:
            btn.set_label("Failed to bind key.")

        self.listening_for = None
        self.btn_next.set_sensitive(True)
        self.btn_prev.set_sensitive(True)
        return True

if __name__ == '__main__':
    win = SetupWindow()
    win.connect("destroy", Gtk.main_quit)
    win.show_all()
    Gtk.main()
