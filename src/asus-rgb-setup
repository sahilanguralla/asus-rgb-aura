def run_cmd(args):
    if DRY_RUN:
        print(f"[AURA] {' '.join(args)}")
        return True
    try:
        subprocess.run(args, check=True)
        return True
    except Exception as e:
        print(f"Error: {e}")
        return False

def set_state(index):
    try:
        os.makedirs(os.path.dirname(STATE_FILE), exist_ok=True)
        with open(STATE_FILE, "w") as f: f.write(str(index))
    except Exception: pass

def get_icon_path(name):
    # Search in common locations
    extensions = [".svg", ".png"]
    for ext in extensions:
        paths = [
            os.path.join(os.path.dirname(__file__), "..", "data", "icons", "aura", f"{name}{ext}"),
            os.path.join(os.path.dirname(__file__), "data", "icons", "aura", f"{name}{ext}"),
            f"/usr/share/asus-rgb-aura/icons/aura/{name}{ext}"
        ]
        for p in paths:
            if os.path.exists(p): return p
    return None

def add_custom_shortcut(shortcut_id, name, command, binding):
    schema = 'org.gnome.settings-daemon.plugins.media-keys'
    key = 'custom-keybindings'
    try:
        output = subprocess.check_output(['gsettings', 'get', schema, key], text=True).strip()
    except Exception: return False
    bindings = ast.literal_eval(output) if output != '@as []' else []
    new_path = f"/org/gnome/settings-daemon/plugins/media-keys/custom-keybindings/{shortcut_id}/"
    if new_path not in bindings: bindings.append(new_path)
    bindings_str = str(bindings).replace("'", '"')
    try:
        subprocess.run(['gsettings', 'set', schema, key, bindings_str], check=True)
        schema_custom = 'org.gnome.settings-daemon.plugins.media-keys.custom-keybinding'
        path_arg = schema_custom + ':' + new_path
        subprocess.run(['gsettings', 'set', path_arg, 'name', name], check=True)
        subprocess.run(['gsettings', 'set', path_arg, 'command', command], check=True)
        subprocess.run(['gsettings', 'set', path_arg, 'binding', binding], check=True)
        return True
    except Exception: return False

class ModeCard(Gtk.Button):
    def __init__(self, name, mode_id, icon_name):
        super().__init__()
        self.mode_id = mode_id
        self.set_relief(Gtk.ReliefStyle.NONE)
        self.get_style_context().add_class("mode-card")
        vbox = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=5)
        
        icon_path = get_icon_path(mode_id)
        if icon_path:
            pixbuf = GdkPixbuf.Pixbuf.new_from_file_at_scale(icon_path, 48, 48, True)
            icon = Gtk.Image.new_from_pixbuf(pixbuf)
        else:
            icon = Gtk.Image.new_from_icon_name(icon_name, Gtk.IconSize.DND)
            icon.set_pixel_size(48)
            
        vbox.pack_start(icon, True, True, 0)
        label = Gtk.Label(label=name)
        vbox.pack_start(label, False, False, 0)
        self.add(vbox)

    def set_active_state(self, is_active):
        if is_active: self.get_style_context().add_class("active")
        else: self.get_style_context().remove_class("active")

