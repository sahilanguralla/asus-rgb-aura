    def create_color_row(self, label):
        hbox = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=10)
        hbox.get_style_context().add_class("settings-row")
        diamond = Gtk.Label(label="◆")
        diamond.get_style_context().add_class("red")
        hbox.pack_start(diamond, False, False, 0)
        hbox.pack_start(Gtk.Label(label=label, xalign=0), True, True, 0)
        btn = Gtk.ColorButton()
        btn.get_style_context().add_class("color-square")
        btn.connect("color-set", self.apply_settings)
        hbox.pack_end(btn, False, False, 0)
        self.settings_panel.pack_start(hbox, False, False, 0)
        return (hbox, btn)

    def create_shortcut_row(self, listbox, label, direction):
        row = Gtk.ListBoxRow()
        row.get_style_context().add_class("settings-row")
        hbox = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=20)
        row.add(hbox)
        hbox.pack_start(Gtk.Label(label=label, xalign=0), True, True, 0)
        btn = Gtk.Button(label="BIND KEY")
        btn.get_style_context().add_class("action-btn")
        btn.connect("clicked", self.on_bind_clicked, direction)
        hbox.pack_end(btn, False, False, 0)
        listbox.add(row)
        return btn

    def on_mode_clicked(self, card):
        self.current_mode = card.mode_id
        self.active_mode_lbl.set_label(card.get_child().get_children()[1].get_text())
        self.update_ui_state()
        self.apply_settings()

    def update_ui_state(self):
        for mid, card in self.mode_cards.items(): card.set_active_state(mid == self.current_mode)
        
        is_dark = self.current_mode == "black"
        self.speed_vbox.set_visible(not is_dark and self.current_mode in ["breathing", "colorcycle", "rainbow"])
        self.brt_vbox.set_visible(not is_dark)
        
        # Color row visibility based on mode
        self.color_rows[0][0].set_visible(not is_dark and self.current_mode in ["static", "breathing", "multi_static"])
        self.color_rows[1][0].set_visible(not is_dark and self.current_mode in ["breathing", "multi_static"])
        self.color_rows[2][0].set_visible(not is_dark and self.current_mode == "multi_static")
        self.color_rows[3][0].set_visible(not is_dark and self.current_mode == "multi_static")

    def apply_settings(self, *args):
        brt = int(self.scale_brt.get_value())
        spd = int(self.scale_speed.get_value())
        colors = [self.get_hex(row[1]) for row in self.color_rows]
        
        if self.current_mode != "black":
            run_cmd(["rogauracore", "brightness", str(brt)])
        
        idx = 8
        if self.current_mode == "black": run_cmd(["rogauracore", "black"]); idx = 11
        elif self.current_mode == "static": run_cmd(["rogauracore", "single_static", colors[0]]); idx = 0
        elif self.current_mode == "breathing": run_cmd(["rogauracore", "single_breathing", colors[0], colors[1], str(spd)]); idx = 10
        elif self.current_mode == "colorcycle": run_cmd(["rogauracore", "single_colorcycle", str(spd)]); idx = 9
        elif self.current_mode == "rainbow": run_cmd(["rogauracore", "rainbow_cycle", str(spd)]); idx = 8
        elif self.current_mode == "multi_static": run_cmd(["rogauracore", "multi_static", colors[0], colors[1], colors[2], colors[3]]); idx = 1
        
        set_state(idx)

    def get_hex(self, btn):
        c = btn.get_rgba()
        return f"{int(c.red*255):02x}{int(c.green*255):02x}{int(c.blue*255):02x}"

    def on_bind_clicked(self, btn, direction):
        self.listening_for = direction
        btn.set_label("WAITING...")
        self.btn_next.set_sensitive(direction == "next")
        self.btn_prev.set_sensitive(direction == "prev")

    def on_key_press(self, widget, event):
        if not self.listening_for: return False
        name = Gdk.keyval_name(event.keyval)
        if not name or any(m in name for m in ["Control", "Shift", "Alt", "Super"]): return False
        mods = ""
        if event.state & Gdk.ModifierType.CONTROL_MASK: mods += "<Primary>"
        if event.state & Gdk.ModifierType.MOD1_MASK: mods += "<Alt>"
        if event.state & Gdk.ModifierType.SHIFT_MASK: mods += "<Shift>"
        if event.state & Gdk.ModifierType.SUPER_MASK: mods += "<Super>"
        binding = mods + name
        success = add_custom_shortcut(f"asus-rgb-{self.listening_for}", f"ASUS RGB {self.listening_for.capitalize()} Effect", f"/usr/bin/asus-rgb-cycle {self.listening_for}", binding)
        btn = self.btn_next if self.listening_for == "next" else self.btn_prev
        btn.set_label(f"BOUND: {binding}" if success else "FAILED")
        self.listening_for = None
        self.btn_next.set_sensitive(True)
        self.btn_prev.set_sensitive(True)
        return True

