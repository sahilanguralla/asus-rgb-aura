def run_cmd(args):
    if DRY_RUN:
        print(f"[DRY-RUN] {' '.join(args)}")
        return True
    try:
        subprocess.run(args, check=True)
        return True
    except Exception as e:
        print(f"Error: {e}")
        return False

def set_state(index):
    try:
        os.makedirs(os.path.dirname(STATE_FILE), exist_ok=True)
        with open(STATE_FILE, "w") as f: f.write(str(index))
    except Exception: pass

class ModeCard(Gtk.Button):
    def __init__(self, name, mode_id, icon_name):
        super().__init__()
        self.mode_id = mode_id
        self.set_relief(Gtk.ReliefStyle.NONE)
        self.get_style_context().add_class("mode-card")

        vbox = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=8)
        
        # Icon
        icon = Gtk.Image.new_from_icon_name(icon_name, Gtk.IconSize.DND)
        icon.set_pixel_size(48)
        vbox.pack_start(icon, True, True, 0)

        # Label
        label = Gtk.Label(label=name)
        label.set_ellipsize(Pango.EllipsizeMode.END)
        vbox.pack_start(label, False, False, 0)

        self.add(vbox)

    def set_active_state(self, is_active):
        if is_active:
            self.get_style_context().add_class("active")
        else:
            self.get_style_context().remove_class("active")

class AsusAuraGui(Gtk.Window):
    def __init__(self):
        super().__init__(title="ASUS Aura Control")
        self.set_default_size(850, 550)
        self.set_position(Gtk.WindowPosition.CENTER)
        
        # Load CSS
        style_provider = Gtk.CssProvider()
        style_provider.load_from_data(CSS.encode())
        Gtk.StyleContext.add_provider_for_screen(
            Gdk.Screen.get_default(), style_provider,
            Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION
        )

        # Header
        hb = Gtk.HeaderBar()
        hb.set_show_close_button(True)
        hb.set_title("ASUS Aura Control")
        self.set_titlebar(hb)

        # Main Layout: Sidebar + Stack
        main_hbox = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL)
        self.add(main_hbox)

        # Stack for pages
        self.stack = Gtk.Stack()
        self.stack.set_transition_type(Gtk.StackTransitionType.CROSSFADE)
        self.stack.set_transition_duration(400)

        # Sidebar
        self.sidebar = Gtk.StackSidebar()
        self.sidebar.set_stack(self.stack)
        self.sidebar.get_style_context().add_class("sidebar")
        self.sidebar.set_size_request(200, -1)
        main_hbox.pack_start(self.sidebar, False, False, 0)

        # Content area
        content_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        main_hbox.pack_start(content_box, True, True, 0)
        content_box.pack_start(self.stack, True, True, 0)

        # Build Pages
        self.build_control_page()
        self.build_shortcuts_page()
        
        self.show_all()

    def build_control_page(self):
        scrolled = Gtk.ScrolledWindow()
        scrolled.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)
        
        vbox = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=24)
        vbox.set_margin_start(30)
        vbox.set_margin_end(30)
        vbox.set_margin_top(20)
        vbox.set_margin_bottom(20)
        scrolled.add(vbox)

        # --- Modes Section ---
        modes_vbox = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=12)
        vbox.pack_start(modes_vbox, False, False, 0)

        lbl = Gtk.Label(label="Lighting Mode", xalign=0)
        lbl.get_style_context().add_class("section-title")
        modes_vbox.pack_start(lbl, False, False, 0)

        flowbox = Gtk.FlowBox()
        flowbox.set_valign(Gtk.Align.START)
        flowbox.set_max_children_per_line(5)
        flowbox.set_selection_mode(Gtk.SelectionMode.NONE)
        flowbox.set_column_spacing(12)
        flowbox.set_row_spacing(12)
        modes_vbox.pack_start(flowbox, False, False, 0)

        modes = [
            ("Static", "static", "preferences-desktop-wallpaper-symbolic"),
            ("Breathing", "breathing", "preferences-system-notifications-symbolic"),
            ("Colorcycle", "colorcycle", "media-playlist-repeat-symbolic"),
            ("Rainbow", "rainbow", "applications-graphics-symbolic"),
            ("Off", "black", "system-shutdown-symbolic"),
        ]

        self.mode_cards = {}
        for name, mid, icon in modes:
            card = ModeCard(name, mid, icon)
            card.connect("clicked", self.on_mode_clicked)
            flowbox.add(card)
            self.mode_cards[mid] = card

        # --- Customization Section ---
        self.custom_card = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=15)
        self.custom_card.get_style_context().add_class("card")
        vbox.pack_start(self.custom_card, False, False, 0)

        lbl = Gtk.Label(label="Customization", xalign=0)
        lbl.get_style_context().add_class("section-title")
        self.custom_card.pack_start(lbl, False, False, 0)

        settings_list = Gtk.ListBox()
        settings_list.get_style_context().add_class("settings-list")
        settings_list.set_selection_mode(Gtk.SelectionMode.NONE)
        self.custom_card.pack_start(settings_list, False, False, 0)

        # Brightness Row
        self.scale_brt = self.create_settings_row(settings_list, "Brightness", 0, 3, 2)
        self.scale_brt.connect("value-changed", self.apply_settings)

        # Speed Row
        self.speed_row, self.scale_speed = self.create_settings_row(settings_list, "Effect Speed", 1, 3, 2, return_row=True)
        self.scale_speed.connect("value-changed", self.apply_settings)

        # Colors Row
        self.color_row = Gtk.ListBoxRow()
        self.color_row.get_style_context().add_class("settings-row")
        color_hbox = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)
        self.color_row.add(color_hbox)
        
        color_hbox.pack_start(Gtk.Label(label="Colors", xalign=0), True, True, 0)
        
        self.color_btn1 = Gtk.ColorButton()
        self.color_btn1.connect("color-set", self.apply_settings)
        color_hbox.pack_end(self.color_btn1, False, False, 0)
        
        self.color_btn2 = Gtk.ColorButton()
        self.color_btn2.connect("color-set", self.apply_settings)
        color_hbox.pack_end(self.color_btn2, False, False, 0)
        
        settings_list.add(self.color_row)

        self.current_mode = "static"
        self.update_ui_state()
        self.stack.add_titled(scrolled, "control", "Lighting Control")

    def build_shortcuts_page(self):
        vbox = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=24)
        vbox.set_margin_start(30)
        vbox.set_margin_end(30)
        vbox.set_margin_top(20)

        card = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=20)
        card.get_style_context().add_class("card")
        vbox.pack_start(card, False, False, 0)

        lbl = Gtk.Label(label="Keyboard Shortcuts", xalign=0)
        lbl.get_style_context().add_class("section-title")
        card.pack_start(lbl, False, False, 0)

        listbox = Gtk.ListBox()
        listbox.get_style_context().add_class("settings-list")
        listbox.set_selection_mode(Gtk.SelectionMode.NONE)
        card.pack_start(listbox, False, False, 0)

        self.btn_next = self.create_shortcut_row(listbox, "Next Effect", "next")
        self.btn_prev = self.create_shortcut_row(listbox, "Previous Effect", "prev")

        self.listening_for = None
        self.connect("key-press-event", self.on_key_press)
        self.stack.add_titled(vbox, "shortcuts", "Shortcuts")

    def create_settings_row(self, listbox, label, lower, upper, default, return_row=False):
        row = Gtk.ListBoxRow()
        row.get_style_context().add_class("settings-row")
        hbox = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=20)
        row.add(hbox)
        hbox.pack_start(Gtk.Label(label=label, xalign=0), True, True, 0)
        adj = Gtk.Adjustment(value=default, lower=lower, upper=upper, step_increment=1)
        scale = Gtk.Scale(orientation=Gtk.Orientation.HORIZONTAL, adjustment=adj)
        scale.set_size_request(200, -1)
        scale.set_digits(0)
        scale.set_draw_value(False)
        hbox.pack_start(scale, False, False, 0)
        listbox.add(row)
        return (row, scale) if return_row else scale

    def create_shortcut_row(self, listbox, label, direction):
        row = Gtk.ListBoxRow()
        row.get_style_context().add_class("settings-row")
        hbox = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=20)
        row.add(hbox)
        hbox.pack_start(Gtk.Label(label=label, xalign=0), True, True, 0)
        btn = Gtk.Button(label="Bind Key")
        btn.get_style_context().add_class("action-btn")
        btn.connect("clicked", self.on_bind_clicked, direction)
        hbox.pack_start(btn, False, False, 0)
        listbox.add(row)
        return btn

    def on_mode_clicked(self, card):
        self.current_mode = card.mode_id
        self.update_ui_state()
        self.apply_settings()

    def update_ui_state(self):
        for mid, card in self.mode_cards.items():
            card.set_active_state(mid == self.current_mode)
        
        self.speed_row.set_visible(self.current_mode in ["breathing", "colorcycle", "rainbow"])
        self.color_row.set_visible(self.current_mode in ["static", "breathing"])
        self.color_btn2.set_visible(self.current_mode == "breathing")

    def apply_settings(self, *args):
        brt = int(self.scale_brt.get_value())
        spd = int(self.scale_speed.get_value())
        c1 = self.get_hex(self.color_btn1)
        c2 = self.get_hex(self.color_btn2)

        run_cmd(["rogauracore", "brightness", str(brt)])
        
        idx = 8
        if self.current_mode == "black":
            run_cmd(["rogauracore", "black"])
            idx = 11
        elif self.current_mode == "static":
            run_cmd(["rogauracore", "single_static", c1])
            idx = 0
        elif self.current_mode == "breathing":
            run_cmd(["rogauracore", "single_breathing", c1, c2, str(spd)])
            idx = 10
        elif self.current_mode == "colorcycle":
            run_cmd(["rogauracore", "single_colorcycle", str(spd)])
            idx = 9
        elif self.current_mode == "rainbow":
            run_cmd(["rogauracore", "rainbow_cycle", str(spd)])
            idx = 8
        
        set_state(idx)

    def get_hex(self, btn):
        c = btn.get_rgba()
        return f"{int(c.red*255):02x}{int(c.green*255):02x}{int(c.blue*255):02x}"

    def on_bind_clicked(self, btn, direction):
        self.listening_for = direction
        btn.set_label("Listening...")
        self.btn_next.set_sensitive(direction == "next")
        self.btn_prev.set_sensitive(direction == "prev")

    def on_key_press(self, widget, event):
        if not self.listening_for: return False
        name = Gdk.keyval_name(event.keyval)
        if not name or "Control" in name or "Shift" in name or "Alt" in name or "Super" in name: return False
        
        mods = ""
        if event.state & Gdk.ModifierType.CONTROL_MASK: mods += "<Primary>"
        if event.state & Gdk.ModifierType.MOD1_MASK: mods += "<Alt>"
        if event.state & Gdk.ModifierType.SHIFT_MASK: mods += "<Shift>"
        if event.state & Gdk.ModifierType.SUPER_MASK: mods += "<Super>"
        binding = mods + name

        cmd = f"ASUS RGB {'Next' if self.listening_for == 'next' else 'Prev'} Effect"
        # Dummy add_shortcut call for this logic
        success = self.mock_add_shortcut(self.listening_for, binding)
        
        btn = self.btn_next if self.listening_for == "next" else self.btn_prev
        btn.set_label(f"Bound: {binding}" if success else "Failed")
        
        self.listening_for = None
        self.btn_next.set_sensitive(True)
        self.btn_prev.set_sensitive(True)
        return True

    def mock_add_shortcut(self, direction, binding):
        # Implementation of add_custom_shortcut from earlier
        # To keep it simple, I'll just call the global function
        return add_custom_shortcut(f"asus-rgb-{direction}", f"ASUS RGB {direction.capitalize()} Effect", f"/usr/bin/asus-rgb-cycle {direction}", binding)

