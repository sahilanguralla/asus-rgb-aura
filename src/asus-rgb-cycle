#!/bin/bash

# A script to cycle through all available RGB modes.
# Usage: asus-rgb-cycle [next|prev] [--dry-run]
# Bind to Fn+Right (next) and Fn+Left (prev) in Ubuntu Keyboard Settings.

STATE_FILE="$HOME/.config/rogauracore_state"
MAX_STATE=11

DRY_RUN=false
if [[ "$*" == *"--dry-run"* ]]; then
    DRY_RUN=true
fi

run_cmd() {
    if [ "$DRY_RUN" = true ]; then
        echo "[DRY-RUN] $*"
    else
        "$@"
    fi
}

# If state file doesn't exist, default to 8 (Rainbow)
if [ ! -f "$STATE_FILE" ]; then
    mkdir -p "$HOME/.config"
    echo "8" > "$STATE_FILE"
fi

STATE=$(cat "$STATE_FILE")

DIRECTION="next"
for arg in "$@"; do
    if [ "$arg" == "next" ] || [ "$arg" == "prev" ]; then
        DIRECTION="$arg"
    fi
done

if [ "$DIRECTION" = "next" ]; then
    STATE=$(( (STATE + 1) % (MAX_STATE + 1) ))
elif [ "$DIRECTION" = "prev" ]; then
    STATE=$(( (STATE - 1 + MAX_STATE + 1) % (MAX_STATE + 1) ))
fi

case $STATE in
    0)
        run_cmd rogauracore red
        ;;
    1)
        run_cmd rogauracore green
        ;;
    2)
        run_cmd rogauracore blue
        ;;
    3)
        run_cmd rogauracore yellow
        ;;
    4)
        run_cmd rogauracore cyan
        ;;
    5)
        run_cmd rogauracore magenta
        ;;
    6)
        run_cmd rogauracore gold
        ;;
    7)
        run_cmd rogauracore white
        ;;
    8)
        run_cmd rogauracore rainbow_cycle 2
        ;;
    9)
        run_cmd rogauracore single_colorcycle 2
        ;;
    10)
        run_cmd rogauracore single_breathing ff0000 0000ff 2
        ;;
    11)
        run_cmd rogauracore black
        ;;
    *)
        # Default fallback to Rainbow
        run_cmd rogauracore rainbow_cycle 2
        STATE=8
        ;;
esac

echo "$STATE" > "$STATE_FILE"
