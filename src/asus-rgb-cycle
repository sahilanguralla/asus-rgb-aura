#!/bin/bash

# A script to cycle through all available RGB modes.
# Usage: asus-rgb-cycle [next|prev]
# Bind to Fn+Right (next) and Fn+Left (prev) in Ubuntu Keyboard Settings.

STATE_FILE="$HOME/.config/rogauracore_state"
MAX_STATE=11

# If state file doesn't exist, default to 8 (Rainbow)
if [ ! -f "$STATE_FILE" ]; then
    mkdir -p "$HOME/.config"
    echo "8" > "$STATE_FILE"
fi

STATE=$(cat "$STATE_FILE")

DIRECTION="${1:-next}"

if [ "$DIRECTION" = "next" ]; then
    STATE=$(( (STATE + 1) % (MAX_STATE + 1) ))
elif [ "$DIRECTION" = "prev" ]; then
    STATE=$(( (STATE - 1 + MAX_STATE + 1) % (MAX_STATE + 1) ))
fi

case $STATE in
    0)
        rogauracore red
        ;;
    1)
        rogauracore green
        ;;
    2)
        rogauracore blue
        ;;
    3)
        rogauracore yellow
        ;;
    4)
        rogauracore cyan
        ;;
    5)
        rogauracore magenta
        ;;
    6)
        rogauracore gold
        ;;
    7)
        rogauracore white
        ;;
    8)
        rogauracore rainbow_cycle 2
        ;;
    9)
        rogauracore single_colorcycle 2
        ;;
    10)
        rogauracore single_breathing ff0000 0000ff 2
        ;;
    11)
        rogauracore black
        ;;
    *)
        # Default fallback to Rainbow
        rogauracore rainbow_cycle 2
        STATE=8
        ;;
esac

echo "$STATE" > "$STATE_FILE"
