#!/bin/bash

# A script to cycle through popular RGB modes.
# Usage: asus-rgb-cycle [next|prev]
# Bind to Fn+Right (next) and Fn+Left (prev) in Ubuntu Keyboard Settings.

STATE_FILE="$HOME/.config/rogauracore_state"
MAX_STATE=6

if [ ! -f "$STATE_FILE" ]; then
    mkdir -p "$HOME/.config"
    echo "0" > "$STATE_FILE"
fi

STATE=$(cat "$STATE_FILE")

DIRECTION="${1:-next}"

if [ "$DIRECTION" = "next" ]; then
    STATE=$(( (STATE + 1) % (MAX_STATE + 1) ))
elif [ "$DIRECTION" = "prev" ]; then
    STATE=$(( (STATE - 1 + MAX_STATE + 1) % (MAX_STATE + 1) ))
fi

case $STATE in
    0)
        rogauracore red
        ;;
    1)
        rogauracore green
        ;;
    2)
        rogauracore blue
        ;;
    3)
        rogauracore rainbow
        ;;
    4)
        rogauracore single_colorcycle
        ;;
    5)
        # single_breathing Color1 Color2 Speed(1-3)
        rogauracore single_breathing ff0000 0000ff 2
        ;;
    6)
        rogauracore black
        ;;
    *)
        rogauracore rainbow
        STATE=3
        ;;
esac

echo "$STATE" > "$STATE_FILE"
